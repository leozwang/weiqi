# .bazelrc
build --action_env=ANDROID_HOME
build --action_env=JAVA_HOME
build --action_env=ANDROID_NDK_HOME

# Android Platforms
build:android_arm64-v8a --android_platforms=//:arm64-v8a
build:android_x86 --android_platforms=//:x86
build --java_language_version=21
build --tool_java_language_version=21
build --java_runtime_version=21
build --tool_java_runtime_version=21
