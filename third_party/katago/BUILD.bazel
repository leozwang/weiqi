load("@rules_cc//cc:defs.bzl", "cc_library", "cc_binary")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "katago_lib",
    srcs = glob(
        [
            "cpp/core/*.cpp",
            "cpp/game/*.cpp",
            "cpp/dataio/*.cpp",
            "cpp/neuralnet/*.cpp",
            "cpp/book/*.cpp",
            "cpp/search/*.cpp",
            "cpp/program/*.cpp",
            "cpp/command/*.cpp",
        ],
        exclude = [
            "cpp/neuralnet/cudabackend.cpp",
            "cpp/neuralnet/cudautils.cpp",
            "cpp/neuralnet/trtbackend.cpp",
            "cpp/neuralnet/metalbackend.cpp",
            "cpp/neuralnet/openclbackend.cpp",
            "cpp/neuralnet/openclkernels.cpp",
            "cpp/neuralnet/openclhelpers.cpp",
            "cpp/neuralnet/opencltuner.cpp",
            "cpp/main.cpp",
        ],
    ) + [
        "cpp/neuralnet/openclbackend.cpp",
        "cpp/neuralnet/openclkernels.cpp",
        "cpp/neuralnet/openclhelpers.cpp",
        "cpp/neuralnet/opencltuner.cpp",
        "cpp/version.cpp",
    ],
    hdrs = glob([
        "cpp/**/*.h",
        "cpp/**/*.hpp",
        "cpp/external/**/*.h",
        "cpp/external/**/*.hpp",
        "cpp/**/*.opencl",
    ]),
    includes = [
        "cpp",
        "cpp/external",
        "cpp/external/tclap-1.2.5/include",
        "cpp/external/filesystem-1.5.8/include",
        "external/opencl/include/CL",
    ],
    defines = [
        "USE_OPENCL_BACKEND",
        "NO_GIT_REVISION",
        "NO_LIBZIP",
        "LITTLE_ENDIAN=1234",
        "BIG_ENDIAN=4321",
        "BYTE_ORDER=LITTLE_ENDIAN",
    ],
    deps = [
        "@bazel_tools//tools/cpp:malloc",
        "@protobuf//:protobuf",
        "@zlib//:zlib",
        ":opencl",
    ],
)

cc_library(
    name = "opencl",
    srcs = [
        "external/opencl/opencl_proxy.cpp",
    ],
    hdrs = glob(["external/opencl/include/CL/CL/*.h"]),
    includes = ["external/opencl/include/CL"],
    linkopts = ["-ldl"],
)

cc_binary(
    name = "libkatago_opencl.so",
    linkshared = 1,
    deps = [":katago_lib"],
)
